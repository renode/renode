# AST2600 full u-boot boot test
# Combined flash image: SPL at 0x0 + FIT u-boot at 0x10000
# Boot ROM (32MB) mirrors SPI flash like QEMU's spi_boot_container

mach create "ast2600"
machine LoadPlatformDescription @platforms/boards/ast2600/ast2600-evb.repl

# Load combined flash image at 0x0 (boot ROM / flash alias)
sysbus LoadBinary @tests/peripherals/Aspeed/firmware/flash.bin 0x0

logLevel 3
uart5 CreateFileBackend @/tmp/uboot-full.txt true
