+static bool file_exists_in_dir(const char_t* directory, const char_t* file_name)
+{
+    char_t file_path[DNNE_MAX_PATH];
+    snprintf(file_path, DNNE_ARRAY_SIZE(file_path), "%s%c%s", directory, DNNE_DIR_SEPARATOR, file_name);
+    return access(file_path, F_OK) == 0;
+}
+
+static bool try_get_portable_runtime_root(const char_t* assembly_path, char_t* buffer)
+{
+    const char_t* last_separator = strrchr(assembly_path, DNNE_DIR_SEPARATOR);
+    if (last_separator == NULL)
+        return false;
+
+    int assembly_dir_len = (int)(last_separator - assembly_path);
+    char_t runtime_root_candidate[DNNE_MAX_PATH];
+    snprintf(runtime_root_candidate, DNNE_ARRAY_SIZE(runtime_root_candidate), "%.*s%c..%c..", assembly_dir_len, assembly_path, DNNE_DIR_SEPARATOR, DNNE_DIR_SEPARATOR);
+
+    if (realpath(runtime_root_candidate, buffer) == NULL)
+        return false;
+
+    if (!file_exists_in_dir(buffer, DNNE_CORECLR_NAME) || !file_exists_in_dir(buffer, "Renode.dll"))
+        return false;
+
+    return true;
+}
+
+static bool try_get_portable_app_path(const char_t* assembly_path, char_t* buffer)
+{
+    char_t runtime_root[DNNE_MAX_PATH];
+    if (!try_get_portable_runtime_root(assembly_path, runtime_root))
+        return false;
+
+    snprintf(buffer, DNNE_MAX_PATH, "%s%c%s", runtime_root, DNNE_DIR_SEPARATOR, "Renode.dll");
+    return true;
+}
