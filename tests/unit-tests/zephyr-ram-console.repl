dram_controller: Python.PythonPeripheral @ sysbus 0x5A003000
    size: 0x400
    initable: true
    script: "request.Value = 0x11111111"

retram: Memory.MappedMemory @ sysbus 0x0
    size: 0x10000

mcusram: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x50000

// autogenerated

nvic0: IRQControllers.NVIC @ {
    sysbus new Bus.BusPointRegistration { address: 0xe000e000; cpu: cpu0 }
}
    -> cpu0@0
    systickFrequency: 209000000

cpu0: CPU.CortexM @ sysbus
    cpuType: "cortex-m4"
    nvic: nvic0

uart4: UART.STM32F7_USART @ sysbus 0x40010000
    frequency: 200000000
    IRQ->nvic0@52

uart7: UART.STM32F7_USART @ sysbus 0x40018000
    frequency: 200000000
    IRQ->nvic0@82


// arrow,stm32mp157a-avenger96 overlay

sysbus:
    init add:
        ApplySVD @https://dl.antmicro.com/projects/renode/svd/STM32MP157x.svd.gz

// st,stm32mp157 overlay

sysbus:
    init add:
        ApplySVD @https://dl.antmicro.com/projects/renode/svd/STM32MP157x.svd.gz
        Tag <0x4C000080 0x4> "HSEM:HSEM_RLR0:M4_MOCK" 0x80000200