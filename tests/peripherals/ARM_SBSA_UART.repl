sysbus:
    init:
        Tag <0xeb3f0000 0x1e00> "ipi_asu / ipi_pmc / ipi0 / ipi1 / ipi2 / ipi3 / ipi4 / ipi5"
        Tag <0xeb310000 0x20> "ipi_asu"
        Tag <0xeb320000 0x20> "ipi_pmc"
        Tag <0xeb330000 0x20> "ipi0"
        Tag <0xeb340000 0x20> "ipi1"
        Tag <0xeb350000 0x20> "ipi2"
        Tag <0xeb360000 0x20> "ipi3"
        Tag <0xeb370000 0x20> "ipi4"
        Tag <0xeb380000 0x20> "ipi5"
        Tag <0xeb390000 0x20> "ipi_pmc_nobuf"
        Tag <0xeb3a0000 0x20> "ipi6"
        Tag <0xeb3b0000 0x20> "ipi_nobuf1"
        Tag <0xeb3b1000 0x20> "ipi_nobuf2"
        Tag <0xeb3b2000 0x20> "ipi_nobuf3"
        Tag <0xeb3b3000 0x20> "ipi_nobuf4"
        Tag <0xeb3b4000 0x20> "ipi_nobuf5"
        Tag <0xeb3b5000 0x20> "ipi_nobuf6"

tcm: Memory.MappedMemory @ sysbus 0x0
    size: 0x10000

sram0: Memory.MappedMemory @ sysbus 0x30000
    size: 0x7ffd0000

ocm: Memory.MappedMemory @ sysbus 0xbbf00000
    size: 0x100000

// autogenerated

gic: IRQControllers.ARM_GenericInterruptController @ {
        sysbus new Bus.BusMultiRegistration { address: 0xe2000000; size: 0x10000; region: "distributor" };
        sysbus new IRQControllers.ArmGicRedistributorRegistration { attachedCPU: cpu0; address: 0xe2100000 }
    }
    architectureVersion: IRQControllers.ARM_GenericInterruptControllerVersion.GICv3

cpu0: CPU.ARMv8R @ sysbus
    cpuType: "cortex-r52"
    cpuId: 0x0
    genericInterruptController: gic

cpu0_timer: Timers.ARM_GenericTimer @ cpu0
    frequency: 62500000
    EL3PhysicalTimerIRQ->gic#0x0@29
    EL1PhysicalTimerIRQ->gic#0x0@30
    EL1VirtualTimerIRQ->gic#0x0@27
    NonSecureEL2PhysicalTimerIRQ->gic#0x0@26

uart0: UART.PL011 @ sysbus 0xf1920000
    sbsa: true
    ->gic@25

uart1: UART.PL011 @ sysbus 0xf1930000
    sbsa: true
    ->gic@26
