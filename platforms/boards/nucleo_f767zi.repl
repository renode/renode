using "platforms/cpus/stm32f777.repl"

GreenLED: Miscellaneous.LED @ gpioPortB 0

BlueLED: Miscellaneous.LED @ gpioPortB 7

RedLED: Miscellaneous.LED @ gpioPortB 14

UserButton1: Miscellaneous.Button @ gpioPortC 13
    invert: true
    -> gpioPortC@13

gpioPortB:
    0 -> GreenLED@0
    7 -> BlueLED@0
    14 -> RedLED@0

phy: Network.EthernetPhysicalLayer @ ethernet 0
    Id1: 0x0007
    Id2: 0xC0F1
    AutoNegotiationAdvertisement: 0x00A1
    AutoNegotiationLinkPartnerBasePageAbility: 0x001
